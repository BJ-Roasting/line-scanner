<!DOCTYPE html>
<html lang="th" class="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Staff Dashboard - Roastery Ops</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#271310", "on-primary": "#ffffff", "primary-container": "#3e2723",
                        surface: "#f4faff", "on-surface": "#111d23", "on-surface-variant": "#504442",
                        "surface-container-lowest": "#ffffff", "surface-container-low": "#e9f6fd",
                        "surface-container-high": "#ddeaf2", "outline-variant": "#d3c3c0",
                        "secondary-container": "#e1e1c9", "on-secondary-container": "#636451",
                        error: "#ba1a1a", "error-container": "#ffdad6"
                    },
                    fontFamily: { sans: ['Noto Sans Thai', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .icon-filled { font-variation-settings: 'FILL' 1; }
        ::-webkit-scrollbar { display: none; }
        #editModalContent { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .modal-open { transform: translateY(0) !important; }
    </style>
</head>
<body class="bg-surface text-on-surface font-sans min-h-screen flex flex-col pb-20 antialiased selection:bg-primary selection:text-on-primary relative">

    <header class="w-full top-0 sticky border-b border-outline-variant bg-surface flex items-center justify-between px-4 h-14 z-40">
        <button class="text-primary hover:bg-surface-container-high active:scale-95 transition-transform p-2 rounded-full -ml-2">
            <span class="material-symbols-outlined text-2xl">menu</span>
        </button>
        <h1 class="text-xl font-bold tracking-tighter text-primary truncate flex-1 text-center">ROASTERY OPS</h1>
        <div class="w-10 h-10 rounded-full bg-primary-container text-on-primary flex items-center justify-center font-bold text-sm">AK</div>
    </header>

    <main class="p-4 flex flex-col gap-6 max-w-md mx-auto w-full z-10">
        <!-- ปุ่มสแกนบาร์โค้ดทั่วไป -->
        <section class="w-full">
            <a href="scanner.html" class="w-full bg-primary text-on-primary rounded-xl py-8 flex flex-col items-center justify-center gap-3 active:scale-[0.98] transition-transform shadow-md block text-center">
                <span class="material-symbols-outlined icon-filled text-5xl">qr_code_scanner</span>
                <span class="text-2xl font-bold">สแกนบาร์โค้ดทั่วไป</span>
            </a>
        </section>

        <!-- ส่วนของ Active Work Orders -->
        <section id="activeWorkOrdersSection">
            <div class="flex justify-between items-center mb-3">
                <h2 class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Active Work Orders</h2>
                <span id="activeWoCount" class="text-xs bg-error-container text-error px-2 py-1 rounded-full font-bold">กำลังโหลด...</span>
            </div>
            
            <div id="workOrderContainer" class="flex flex-col gap-3">
                <div class="text-center py-6 text-on-surface-variant animate-pulse font-bold text-sm bg-surface-container-lowest rounded-lg border border-outline-variant">
                    <span class="material-symbols-outlined animate-spin align-middle mr-1">sync</span> กำลังดึงข้อมูลใบงาน...
                </div>
            </div>
        </section>
    </main>

    <!-- หน้าต่างแก้ไขใบงาน -->
    <div id="editModal" class="fixed inset-0 bg-on-surface/50 z-50 hidden flex-col justify-end items-center px-2 pb-2">
        <div class="bg-surface w-full max-w-md rounded-2xl p-6 shadow-xl transform translate-y-full" id="editModalContent">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-primary">ดู / แก้ไขข้อมูลใบงาน</h3>
                <button onclick="closeEditModal()" class="text-on-surface-variant hover:text-error bg-surface-container-low p-1 rounded-full">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-bold text-on-surface-variant uppercase">รหัสใบงาน</label>
                    <input type="text" id="editWoId" disabled class="w-full px-3 py-2 bg-surface-container-lowest border border-outline-variant rounded-lg font-mono font-bold text-primary opacity-70">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-bold text-on-surface-variant uppercase">เป้าหมาย (Limit)</label>
                    <input type="number" id="editLimit" class="w-full px-3 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg text-primary font-bold focus:border-primary outline-none">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-bold text-on-surface-variant uppercase">กิโล/กระสอบ</label>
                        <input type="number" id="editKg" class="w-full px-3 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg text-primary font-bold focus:border-primary outline-none">
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-bold text-on-surface-variant uppercase">รหัส Lot</label>
                        <input type="text" id="editLot" class="w-full px-3 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg text-primary font-bold focus:border-primary outline-none uppercase">
                    </div>
                </div>
                <button onclick="saveEditData()" id="btnSaveEdit" class="w-full bg-primary text-on-primary font-bold py-4 rounded-xl mt-2 shadow-sm active:scale-[0.98] transition-transform flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined">save</span>
                    บันทึกการแก้ไขใบงาน
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Navigation Bar -->
    <nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-2 py-2 bg-surface border-t border-outline-variant z-40">
        <a href="index.html" class="flex flex-col items-center justify-center text-primary bg-secondary-container rounded-full px-5 py-1.5 active:scale-90 transition-all duration-150">
            <span class="material-symbols-outlined text-[24px] icon-filled">dashboard</span>
            <span class="text-[10px] font-bold mt-1">หน้าแรก</span>
        </a>
        <button onclick="alert('หน้าคั่วกาแฟกำลังพัฒนาครับ')" class="flex flex-col items-center justify-center text-on-surface-variant px-5 py-1.5 hover:bg-surface-container-high rounded-full active:scale-90 transition-all duration-150">
            <span class="material-symbols-outlined text-[24px]">local_fire_department</span>
            <span class="text-[10px] font-bold mt-1">คั่วกาแฟ</span>
        </button>
        <a href="admin_dashboard.html" class="flex flex-col items-center justify-center text-on-surface-variant px-5 py-1.5 hover:bg-surface-container-high rounded-full active:scale-90 transition-all duration-150">
            <span class="material-symbols-outlined text-[24px]">list_alt</span>
            <span class="text-[10px] font-bold mt-1">แอดมิน</span>
        </a>
    </nav>

    <script>
        // 🚀 URL ของระบบ API หลังบ้าน
        const API_URL = "https://script.google.com/macros/s/AKfycbzxKRgC-DyvyuRWPP2ibCw64fENrVx7qF4WO6997w4oLFtLnM84z5LAbhghD8o6YKPl/exec";

        document.addEventListener("DOMContentLoaded", loadWorkOrders);

        function handleCardClick(link) { window.location.href = link; }

        function handleEditClick(woId, limit, kg, lot, event) {
            event.stopPropagation(); 
            openEditModal(woId, limit, kg, lot);
        }

        function openEditModal(woId, limit, kg, lot) {
            document.getElementById('editWoId').value = woId;
            document.getElementById('editLimit').value = limit;
            document.getElementById('editKg').value = kg === 'undefined' ? '' : kg;
            document.getElementById('editLot').value = lot === 'undefined' ? '' : lot;
            
            const modal = document.getElementById('editModal');
            const content = document.getElementById('editModalContent');
            modal.classList.remove('hidden'); modal.classList.add('flex');
            setTimeout(() => { content.classList.add('modal-open'); }, 10);
        }

        function closeEditModal() {
            const modal = document.getElementById('editModal');
            const content = document.getElementById('editModalContent');
            content.classList.remove('modal-open');
            setTimeout(() => { modal.classList.add('hidden'); modal.classList.remove('flex'); }, 300);
        }

        // ฟังก์ชันบันทึกแก้ไขใบงานผ่าน Fetch API
        function saveEditData() {
            const btn = document.getElementById('btnSaveEdit');
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> กำลังบันทึก...';
            btn.disabled = true;

            const payload = {
                action: "updateWorkOrder",
                data: {
                    woId: document.getElementById('editWoId').value,
                    targetLimit: document.getElementById('editLimit').value,
                    kgPerBag: document.getElementById('editKg').value,
                    lotCode: document.getElementById('editLot').value
                }
            };

            fetch(API_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(res => {
                if (res.status === 'success') {
                    alert(res.message);
                    closeEditModal();
                    loadWorkOrders(); 
                } else {
                    alert("เกิดข้อผิดพลาด: " + res.message);
                }
            })
            .catch(err => alert("ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้"))
            .finally(() => {
                btn.innerHTML = '<span class="material-symbols-outlined">save</span> บันทึกการแก้ไข';
                btn.disabled = false;
            });
        }

        // ฟังก์ชันโหลดข้อมูลผ่าน Fetch API
        function loadWorkOrders() {
            const container = document.getElementById('workOrderContainer');
            const badge = document.getElementById('activeWoCount');
            const section = document.getElementById('activeWorkOrdersSection');

            fetch(API_URL + "?action=getActiveWorkOrders")
                .then(res => res.json())
                .then(res => {
                    if (res.status !== 'success' || !res.data || res.data.length === 0) {
                        section.style.display = 'block';
                        badge.innerText = '0 รอดำเนินการ';
                        container.innerHTML = `
                            <div class="text-center py-8 text-on-surface-variant bg-surface-container-lowest rounded-lg border border-outline-variant shadow-sm flex flex-col items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-4xl text-outline-variant">task_alt</span>
                                <span class="font-bold text-sm">ไม่มีใบงานค้างอยู่</span>
                            </div>`;
                        return;
                    }

                    section.style.display = 'block';
                    container.innerHTML = ''; 
                    badge.innerText = res.data.length + ' รอดำเนินการ';
                    
                    res.data.forEach(function(wo) {
                        let typeText = "งาน", unit = "รายการ", link = "#";
                        let borderColor = "border-primary", labelBg = "bg-secondary-container", labelText = "text-on-secondary-container";
                        
                        if(wo.type === "INBOUND") {
                            typeText = "รับเข้า"; unit = "กระสอบ";
                            link = `scanner.html?woId=${wo.woId}&kg=${wo.kgPerBag || 40}`; 
                        }

                        if(wo.status === "Re-opened") {
                            borderColor = "border-error"; labelBg = "bg-error-container"; labelText = "text-error";
                        }

                        let supplierHtml = wo.supplier ? `<p class="text-[11px] text-on-surface-variant mt-0.5 whitespace-nowrap overflow-hidden text-ellipsis w-48">จาก: ${wo.supplier}</p>` : '';

                        let cardHtml = `
                        <div onclick="handleCardClick('${link}')" class="bg-surface-container-lowest border-2 ${borderColor} rounded-lg p-4 flex flex-col gap-3 shadow-sm relative overflow-hidden active:scale-[0.98] transition-transform cursor-pointer select-none">
                            <div class="absolute left-0 top-0 bottom-0 w-1 ${wo.status === 'Re-opened' ? 'bg-error' : 'bg-primary'} rounded-l-lg"></div>
                            <div class="flex justify-between items-start">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-mono font-bold text-primary bg-surface-container-high px-2 py-1 rounded">${wo.woId}</span>
                                        <button onclick="handleEditClick('${wo.woId}', '${wo.limit}', '${wo.kgPerBag || ''}', '${wo.lotCode || ''}', event)" class="text-on-surface-variant hover:text-primary p-1 bg-surface-container-low rounded-full flex items-center justify-center transition-colors active:scale-90 border border-outline-variant">
                                            <span class="material-symbols-outlined text-[16px]">visibility</span>
                                        </button>
                                    </div>
                                    <h3 class="text-lg font-bold text-primary mt-1">${typeText}: ${wo.item}</h3>
                                    ${supplierHtml}
                                </div>
                                <span class="text-[10px] font-bold ${labelBg} ${labelText} px-2 py-1 rounded uppercase whitespace-nowrap">${wo.status}</span>
                            </div>
                            <div class="flex justify-between items-end border-t border-outline-variant pt-3">
                                <div class="flex flex-col">
                                    <span class="text-xs text-on-surface-variant font-bold uppercase">ความคืบหน้า</span>
                                    <div class="flex items-baseline gap-1">
                                        <span class="font-mono text-xl font-bold text-primary">${wo.actual}</span>
                                        <span class="font-mono text-sm text-on-surface-variant">/ ${wo.limit} ${unit}</span>
                                    </div>
                                </div>
                                <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary text-[20px]">arrow_forward</span>
                                </div>
                            </div>
                        </div>`;
                        container.innerHTML += cardHtml;
                    });
                })
                .catch(err => {
                    container.innerHTML = `<div class="text-center py-6 text-error font-bold text-sm bg-error-container rounded-lg">เกิดข้อผิดพลาดในการโหลดข้อมูล</div>`;
                });
        }
    </script>
</body>
</html>
